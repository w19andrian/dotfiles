#!/usr/bin/env bash
set -euo pipefail

ROOT="$HOME/Projekt"
CREATE_LABEL="[+] Create new project"
DEFAULT_TERM_LABEL=" Just gimme the goddamn terminal!!"
DEFAULT_TERM_NAME="termy_4_normy"
OS_NAME=$(uname | tr '[:upper:]' '[:lower:]')
_find_bin="find" # initialize _find_bin var for visibility. Will be checked again by set_find_bin()

usage() {
	cat <<EOF
Usage:
  p <project-name>

Switch to an existing project session.

Projects live under:
  $ROOT
EOF
}

require_program() {
	local prog
	prog=$1
	if ! command -v "${prog}" >/dev/null 2>&1; then
		echo "Error: ${prog} is not installed or not in PATH."
		echo "Please install ${prog} to use this command."
		exit 1
	fi
}

set_find_bin() {
	if [[ "${OS_NAME}" == "darwin" ]]; then
		_find_bin="gfind"
		require_program "${_find_bin}"
	fi
}

switch_or_attach() {
	local name="$1"
	local dir="$ROOT/$name"

	if ! tmux has-session -t "$name" 2>/dev/null; then
		tmux new-session -d -s "$name" -c "$dir"
	fi

	if [[ -n "${TMUX:-}" ]]; then
		tmux switch-client -t "$name"
	else
		tmux attach -t "$name"
	fi
}

create_project() {
	read -rp "New project name: " name
	[[ -z "$name" ]] && exit 0

	if is_repo_url "$name"; then
		echo "repository URL has been detected"
		name=$(basename "$name")

		git clone "$name" "$ROOT/$name"
	else
		mkdir -p "$ROOT/$name"
	fi

	switch_or_attach "$name"
}

is_repo_url() {
	local _git_https='^http(s)?:\/\/([a-z 0-9]*\.)+[a-z]*\/.*\.git$'
	local _git_ssh='^(ssh:\/\/)?git\@([a-z 0-9]*\.)+[a-z]*(\:[0-9]+)?\/[a-z 0-9]*\/.*\.git$'

	if [[ "${1}" =~ $_git_https || "${1}" =~ $_git_ssh ]]; then
		return 0
	else
		return 1
	fi
}

interactive_mode() {
	{
		"${_find_bin}" "$ROOT" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' | sort
		echo "===================="
		echo "$DEFAULT_TERM_LABEL"
		echo "────────────────────"
		echo "$CREATE_LABEL"
	} | fzf --prompt="Projekt > " --height=40% --reverse --tac
}

main() {
	require_program "tmux"
	set_find_bin

	if [[ $# -eq 0 ]]; then
		if command -v fzf >/dev/null 2>&1; then
			selection="$(interactive_mode || true)"
			[[ -z "$selection" ]] && exit 0

			if [[ "$selection" == "$CREATE_LABEL" ]]; then
				create_project
			elif [[ "$selection" == "$DEFAULT_TERM_LABEL" ]]; then
				switch_or_attach "$DEFAULT_TERM_NAME"
			elif [[ "$selection" != "────────────────────" && "$selection" != "====================" ]]; then
				switch_or_attach "$selection"
			fi
		else
			usage
		fi
		exit 0
	fi

	name="$1"
	dir="$ROOT/$name"

	if [[ ! -d "$dir" ]]; then
		echo "Project does not exist: $name"
		exit 1
	fi

	switch_or_attach "$name"
}

main "$@"
