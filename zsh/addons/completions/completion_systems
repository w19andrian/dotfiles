cache_dir="${_zsh_completions_dir}/cache"

# 1Password 
eval "$(op completion zsh)"; compdef _op op

# kubectl
eval "$(kubectl completion zsh)"; compdef _kubectl kubectl

# kustomize
eval "$(kustomize completion zsh)"; compdef _kustomize kustomize

# hugo
eval "$(hugo completion zsh)"; compdef _hugo hugo

# poetry
[[ ! -f "${cache_dir}/_poetry" ]] && poetry completions zsh > "${cache_dir}/_poetry"
