{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "calm_blue": "#5D92D4",
    "calm_green": "#5EA666",
    "calm_red": "#CC6060",
    "cyan": "#99FFE4",
    "yellow": "#FFC799",
    "white": "#EDECEB",
    "k8s_blue": "#326CE5"
  },
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "p:cyan",
          "options": {
            "style": "agnoster"
          },
          "style": "plain",
          "template": "{{ if .Segments.Git }}{{ trimPrefix (regexReplaceAll (printf \"(^.+/)%s.*\" .Segments.Git.RepoName) .Location \"$1\") .Location }}{{ else }}{{ .Path }}{{ end }}",
          "type": "path"
        },
        {
          "foreground": "p:yellow",
          "options": {
            "fetch_status": true,
            "branch_icon": "",
            "branch_identical_icon": "eq",
            "branch_ahead_icon": "gt",
            "branch_behind_icon": "lt"
          },
          "style": "plain",
          "template": " :: {{ .HEAD }}{{ if .BranchStatus }}[{{ .BranchStatus }}]{{ end }}",
          "type": "git"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "foreground": "p:white",
          "background": "p:calm_red",
          "options": {
            "fetch_status": true,
            "branch_icon": ""
          },
          "style": "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "template": "{{ if .Working.Changed }}{{ .Working.String }}{{ end }}",
          "type": "git"
        },
        {
          "foreground": "p:white",
          "background": "p:calm_green",
          "options": {
            "fetch_status": true,
            "branch_icon": ""
          },
          "style": "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "template": "{{ if .Staging.Changed }}{{ .Staging.String }}{{ end }}",
          "type": "git"
        }
      ],
      "type": "rprompt"
    }
  ],
  "tooltips_action": "replace",
  "tooltips": [
    {
      "type": "kubectl",
      "tips": ["k", "kx", "kns", "kubectl", "kubens", "kubectx", "helm"],
      "foreground": "p:white",
      "background": "p:k8s_blue",
      "leading_diamond": "",
      "trailing_diamond": "",
      "style": "diamond",
      "template": "{{ if .Context }}\udb84\udcfe {{ .Context }}{{ if .Namespace }}({{ .Namespace }}){{ end }}{{ end }}"
    }
  ],
  "final_space": true,
  "version": 4
}
